{
  "name": "@dreamlog/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "prisma generate && esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js --external:@hono/node-server --external:@prisma/client --external:@supabase/supabase-js --external:@anthropic-ai/sdk --external:hono --external:dotenv --external:web-push --external:zod",
    "start": "prisma migrate deploy && node dist/index.js",
    "lint": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@dreamlog/shared": "workspace:*",
    "@hono/node-server": "^1.13.0",
    "@prisma/client": "^6.1.0",
    "@supabase/supabase-js": "^2.47.0",
    "@anthropic-ai/sdk": "^0.32.0",
    "hono": "^4.6.0",
    "dotenv": "^16.4.0",
    "web-push": "^3.6.7",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "esbuild": "^0.24.0",
    "prisma": "^6.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "@types/node": "^22.10.0",
    "@types/web-push": "^3.6.4"
  }
}
